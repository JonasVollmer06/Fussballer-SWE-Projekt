meta {
  name: Suche mit vorhandener ID (ungültiger Token)
  type: http
  seq: 3
}

get {
  url: {{restUrl}}/:id
  body: none
  auth: bearer
}

params:path {
  id: 30
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{Token}}UNGUELTIG
}

assert {
  res.status: eq 401
}

settings {
  encodeUrl: true
  timeout: 0
}
