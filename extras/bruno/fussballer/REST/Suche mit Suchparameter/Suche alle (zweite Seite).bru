meta {
  name: Suche alle (zweite Seite)
  type: http
  seq: 2
}

get {
  url: {{restUrl}}?page=1
  body: none
  auth: inherit
}

params:query {
  page: 1
}

headers {
  Accept: application/json
}

assert {
  res.status: eq 200
  res.headers['content-type']: eq application/json
  res.body.content: isArray
  res.body.content: isNotEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
