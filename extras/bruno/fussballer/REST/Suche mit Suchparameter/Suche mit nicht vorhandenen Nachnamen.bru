meta {
  name: Suche mit nicht vorhandenen Nachnamen
  type: http
  seq: 4
}

get {
  url: {{restUrl}}?nachname=Kolb
  body: none
  auth: inherit
}

params:query {
  nachname: Kolb
}

headers {
  Accept: application/json
}

assert {
  res.status: eq 404
}

settings {
  encodeUrl: true
  timeout: 0
}
