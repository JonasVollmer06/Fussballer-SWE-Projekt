meta {
  name: DB neuladen
  type: http
  seq: 1
}

post {
  url: {{devUrl}}/db_populate
  body: none
  auth: oauth2
}

auth:oauth2 {
  grant_type: password
  access_token_url: {{oidcTokenUrl}}
  refresh_token_url: 
  username: {{username}}
  password: {{password}}
  client_id: python-client
  client_secret: kGXH5uWL4yOyIpGxkOa4marnjMhDwjem
  scope: 
  credentials_placement: body
  credentials_id: credentials
  token_placement: header
  token_header_prefix: Bearer
  auto_fetch_token: true
  auto_refresh_token: false
}

vars:pre-request {
  username: admin
  password: p
}

assert {
  res.status: eq 200
  res.headers['content-type']: eq application\/json
  res.body.db_populate: eq success
}

settings {
  encodeUrl: true
  timeout: 0
}
